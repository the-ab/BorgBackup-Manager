# BorgBackup Manager – Beispielkonfiguration
# Diese Datei nicht unverändert produktiv verwenden. Für eine geführte
# Konfiguration `bash install.sh` ausführen.

# Zeitzone für WebUI, Zeitpläne und remote gestartete Borg-Befehle.
TZ=Europe/Berlin

# Veröffentlichte Host-Ports.
BBM_HTTPS_PORT=8443
BBM_REPOSITORY_SSH_PORT=2222

# DNS-Name oder IP-Adresse, unter der Backup-Geräte den Manager erreichen.
BBM_REPOSITORY_PUBLIC_HOST=backup-manager.example.org

# Namen/IPs für die erstmalige Erzeugung des TLS-Zertifikats. Ein bereits
# verschlüsselt gespeichertes Zertifikat wird dadurch nicht automatisch ersetzt.
BBM_TLS_HOSTS=backup-manager.example.org,localhost,127.0.0.1

# Persistente Host-Verzeichnisse. Beide Pfade müssen absolut sein.
BBM_DATA_PATH=/docker_data/borgbackup-manager/data
BBM_REPOSITORY_PATH=/docker_data/borgbackup-manager/repositories

# UID/GID des eingeschränkten Borg-Benutzers im Container.
BBM_BORG_UID=1000
BBM_BORG_GID=1000

# Sitzungs- und Laufzeitgrenzen. Die Sitzung endet nach 24 Stunden absolut
# beziehungsweise nach 60 Minuten Inaktivität.
BBM_SESSION_TTL_SECONDS=86400
BBM_SESSION_IDLE_TIMEOUT_SECONDS=3600
BBM_SESSION_COOKIE_NAME=bbm_session_v2
# always ist der sichere Standard. auto/never nur für ausdrücklich geprüfte
# Sonderkonfigurationen verwenden.
BBM_SESSION_COOKIE_SECURE=always
# Forwarded-/X-Forwarded-* Header werden ausschließlich von diesen Netzen
# akzeptiert. Reverse-Proxy-Netze bei Bedarf explizit ergänzen.
BBM_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# Persistente Begrenzung teurer Login-Prüfungen.
BBM_LOGIN_RATE_WINDOW_SECONDS=300
BBM_LOGIN_RATE_BLOCK_SECONDS=900
BBM_LOGIN_RATE_MAX_PER_IP=20
BBM_LOGIN_RATE_MAX_PER_IP_USER=5

# Aufbewahrung und maximale Anzahl von Sicherheitsereignissen.
BBM_SECURITY_EVENT_RETENTION_DAYS=90
BBM_SECURITY_EVENT_MAX_ROWS=10000

# Grenzen für Manager-Backup-Dateien und entpackte Restore-Inhalte.
BBM_BACKUP_MAX_FILE_BYTES=268435456
BBM_BACKUP_MAX_UNCOMPRESSED_BYTES=1073741824
BBM_BACKUP_MAX_ENTRIES=5000
BBM_BACKUP_MAX_COMPRESSION_RATIO=250
BBM_COMMAND_TIMEOUT=86400

# Standardwerte für eine neue settings.json. Spätere Änderungen erfolgen in
# der WebUI und werden persistent gespeichert.
BBM_APPEARANCE=auto
BBM_REPOSITORY_SIZE_AFTER_RUN=1
# 0 = unbegrenzt; die WebUI kann diesen Wert später persistent überschreiben.
BBM_MAX_PARALLEL_RUNS=0

# Standardwerte für den Speicherplatzschutz. Spätere globale Änderungen und
# repositorybezogene Abweichungen werden in der WebUI gespeichert.
BBM_STORAGE_GUARD_ENABLED=1
BBM_STORAGE_GUARD_THRESHOLD_PERCENT=95

# Strenge Bereitschaftsprüfung des internen Repository-SSH-Dienstes.
BBM_HEALTH_REQUIRE_SSHD=1

# Rotation der Repository-SSH-Protokolle.
BBM_LOG_MAX_BYTES=10485760
BBM_LOG_ROTATIONS=5
BBM_DEBUG_LOG_LEVEL=WARNING

# Nur für die einmalige Migration alter Zertifikatsdateien innerhalb des
# Containers. Für aktuelle Installationen normalerweise nicht setzen.
# BBM_TLS_CERT_FILE=/data/tls/fullchain.pem
# BBM_TLS_KEY_FILE=/data/tls/privkey.pem
